{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfakshaye"
		},
		"Adls_on_prem_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'Adls_on_prem'"
		},
		"AzureBlobStorage1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'AzureBlobStorage1'"
		},
		"linked_servisedl_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'linked_servisedl'"
		},
		"onpremisessms_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'onpremisessms'"
		},
		"Adls_on_prem_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlslakeaksh.dfs.core.windows.net/"
		},
		"linked_servisedl_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://akshaefactory.dfs.core.windows.net/"
		},
		"linkedgit_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com"
		},
		"onpremisessms_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost\\SQLEXPRESS"
		},
		"onpremisessms_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "DataWarehouse"
		},
		"onpremisessms_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "AKSHAY\\Admin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfakshaye_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureBlobStorage1_connectionString": {
						"value": "[parameters('AzureBlobStorage1_connectionString')]"
					},
					"onpremisessms_password": {
						"value": "[parameters('onpremisessms_password')]"
					},
					"Adls_on_prem_accountKey": {
						"value": "[parameters('Adls_on_prem_accountKey')]"
					},
					"linked_servisedl_accountKey": {
						"value": "[parameters('linked_servisedl_accountKey')]"
					},
					"onpremisessms_properties_typeProperties_server": {
						"value": "[parameters('onpremisessms_properties_typeProperties_server')]"
					},
					"onpremisessms_properties_typeProperties_database": {
						"value": "[parameters('onpremisessms_properties_typeProperties_database')]"
					},
					"onpremisessms_properties_typeProperties_userName": {
						"value": "[parameters('onpremisessms_properties_typeProperties_userName')]"
					},
					"Adls_on_prem_properties_typeProperties_url": {
						"value": "[parameters('Adls_on_prem_properties_typeProperties_url')]"
					},
					"linked_servisedl_properties_typeProperties_url": {
						"value": "[parameters('linked_servisedl_properties_typeProperties_url')]"
					},
					"linkedgit_properties_typeProperties_url": {
						"value": "[parameters('linkedgit_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}